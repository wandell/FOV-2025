{
    "chat.tools.terminal.autoApprove": {
        "mv": true
    },
    "files.associations": {
        "*.bib": "bibtex"
    },
    "bibtex-tidy.sort": [
        "key"
    ],
    "[bibtex]": {
        "editor.defaultFormatter": "xrimson.bibtex-tidy",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        }
    },
    "[bib]": {
        "editor.defaultFormatter": "xrimson.bibtex-tidy"
    }
}