{
    "files.associations": {
        "*.bib": "bibtex"
    },
    "bibtex-tidy.options": {
        "sort": [
            "key"
        ]
    },
    "[bibtex]": {
        "editor.defaultFormatter": "Xrimson.bibtex-tidy",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        }
    },
    "[bib]": {
        "editor.defaultFormatter": "Xrimson.bibtex-tidy"
    }
}